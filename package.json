{
  "name": "retort-plugins",
  "private": true,
  "description": "IDE plugins for the Retort framework — VSCode and PyCharm",
  "packageManager": "pnpm@9.15.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenixvc/retort-plugins.git"
  },
  "license": "MIT",
  "workspaces": [
    "packages/router",
    "packages/ui",
    "packages/state-watcher",
    "extensions/vscode"
  ],
  "scripts": {
    "build": "pnpm --filter @retort-plugins/router build && pnpm --filter @retort-plugins/ui build && pnpm --filter @retort-plugins/state-watcher build && pnpm --filter @retort-plugins/vscode build",
    "build:router": "pnpm --filter @retort-plugins/router build",
    "build:ui": "pnpm --filter @retort-plugins/ui build",
    "build:watcher": "pnpm --filter @retort-plugins/state-watcher build",
    "build:vscode": "pnpm --filter @retort-plugins/vscode build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
