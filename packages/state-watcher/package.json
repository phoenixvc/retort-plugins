{
  "name": "@retort-plugins/state-watcher",
  "version": "0.1.0",
  "private": true,
  "description": "WebSocket state-watcher daemon for Retort — watches workspace files and streams state to IDE plugins",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  }
}
